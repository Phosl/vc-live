{
  "name": "vibe-screen-reader-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mini web app locale per leggere ad alta voce una zona dello schermo con OpenAI Vision + TTS.",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c green,cyan \"node server.js\" \"vite --host 127.0.0.1\"",
    "dev:api": "node server.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "concurrently": "8.2.2",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "openai": "6.45.0",
    "vite": "5.4.21"
  },
  "engines": {
    "node": ">=20.9"
  }
}
