# Copia questo file in .env e inserisci la tua chiave.
# Non committare mai .env su GitHub.
OPENAI_API_KEY=sk-proj_INSERISCI_LA_TUA_CHIAVE_QUI

# Backend locale
PORT=3000

# Modello vision per leggere l'immagine catturata dal rettangolo.
# Puoi cambiarlo se nel tuo account usi un modello diverso.
OPENAI_VISION_MODEL=gpt-4.1-mini

# Voce femminile naturale OpenAI. "amber" e' una voce dell'esperienza ChatGPT,
# ma al momento non risulta tra le voci documentate per questa API.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Live API / Realtime
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=coral

# Ogni quanti millisecondi ricontrollare il rettangolo quando è attiva la modalità live.
VITE_READ_INTERVAL_MS=6000
